                                            <button class="btn btn-dark w-47 mt-3" onclick="rePrintPdf()">
                                                Fahrradpass Drucken <i class="bi bi-printer ms-2"></i>
                                            </button>
                                        </div>
                                        <form id="rePrintFahrradForm">
                                            <input type="hidden" name="rePrintRahmennummer" id="rePrintRahmennummer" />
                                            <input type="hidden" name="rePrintSchlüsselnummer" id="rePrintSchlüsselnummer" />
                                            <input type="hidden" name="rePrintAkkunummer" id="rePrintAkkunummer" />
                                            <input type="hidden" name="rePrintZubehoerTasche" id="rePrintZubehoerTasche" />
                                            <input type="hidden" name="rePrintGabelNummer" id="rePrintGabelNummer" />
                                            <input type="hidden" name="rePrintBikeId" id="rePrintBikeId" />
                                        </form>


                                    </div>
                                </div>
                                


                            </div>
                        </div>
                    </div>
                    <!-- Right panel -->
                    <div class="col-md-3">
                        <div class="right-panel">
                            

                            <div id="homeScreen">
                                <div class="text-center">
                                    <h4 class="fw-bold">Etiketten & Nummern drucken</h4>
                                </div>
                                <div id="createJobBtn">
                                    <label>Fahrrad-Pass aufrufen</label>
                                    <input type="text" id="barcodeInput" name="barcode" onkeydown="handleKeyDown(event)" />
                                    
                                </div>

                            </div>
                            <div id="bikeInfoBox" style="display:none;">
                                <img id="bikeImage" src="" alt="Produktbild" style="max-width:100%; max-height:130px; margin-bottom:5px; display:none;" />
                                <strong>Brand:</strong> <span id="brand"></span><br />
                                <strong>Model:</strong> <span id="model"></span><br />
                                <strong>Artikelnummer:</strong> <span id="articleNumber"></span><br />
                                <strong>EAN:</strong> <span id="ean"></span>

                                <div id="extraInfo" class="mt-3 mb-4">
                                    @*<p style="cursor: pointer;" id="toggleInfo">
                                            <i class="bi bi-info-circle m-1" style="font-size: 15px;"></i>
                                            <strong>Zusätzliche Informationen</strong>
                                            <i id="toggleInfoIcon" class="bi bi-chevron-down m-1" style="font-size: 15px;"></i>
                                        </p>*@
                                    <ul id="extraInfoList" style="list-style: none;padding: 0;">
                                        <li><strong>Kategorie:</strong> <span id="kategorie"></span></li>
                                        <li><strong>Rahmentyp:</strong> <span id="rahmentyp"></span></li>
                                        <li><strong>Rahmenmaterial:</strong> <span id="rahmenmaterial"></span></li>
                                        <li><strong>Schaltung:</strong> <span id="schaltung"></span></li>
                                        <li><strong>Radgröße:</strong> <span id="radgroesse"></span></li>
                                        <li><strong>Rahmenhöhe:</strong> <span id="rahmenhoehe"></span></li>
                                        <li><strong>Farbe:</strong> <span id="farbe"></span></li>
                                        <li><strong id="akkuHead">Akku:</strong> <span id="akku"></span></li>
                                    </ul>
                                </div>
                                <input type="hidden" name="bikeId" id="bikeId" />
                                <input type="hidden" name="bikeBrand" id="bikeBrand" />
                                <div id="isDifficultCheckboxContainer" class="form-check mt-1" style="display:none">
                                    <input class="form-check-input" name="isDifficultCheckbox" type="checkbox" id="isDifficultCheckbox" />
                                    <label class="form-check-label" for="isDifficultCheckbox">
                                        Schweres Rad
                                    </label>
                                </div>
                                
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
