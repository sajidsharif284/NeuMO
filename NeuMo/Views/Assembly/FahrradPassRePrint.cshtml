    <script>
    let errorTimeout;

    function showErrorMessage(message) {
        clearTimeout(errorTimeout);
        const banner = document.getElementById("errorMessage");
        const text = document.getElementById("errorText");
        text.textContent = message;
        banner.style.display = "flex";
        errorTimeout = setTimeout(() => {
            hideErrorMessage();
        }, 8000);
    }

    function hideErrorMessage() {
        document.getElementById("errorMessage").style.display = "none";
        const input = document.getElementById("barcodeInput");
        input.focus();
    }

    function rePrintBarcodeFromPreview(previewId) {
        const value = document.getElementById(previewId)?.innerText.trim();
        if (!value || value === "--") return;

        const formData = new FormData();
        formData.append("headingValue", previewId);
        formData.append("barcodeValue", value);

        const newTab = window.open();
        if (!newTab) {
            alert("Bitte Pop-ups im Browser erlauben.");
            return;
        }

        fetch('@Url.Action("GenerateBarcodePdf", "Assembly")', {
            method: 'POST',
            body: formData
        })
        .then(response => {
            if (!response.ok) throw new Error("PDF konnte nicht erstellt werden.");
            return response.blob();
        })
        .then(blob => {
            const url = URL.createObjectURL(blob);
            newTab.document.write(`
                <html>
                    <head><title>Barcode Drucken</title></head>
                    <body style="margin:0">
                        <embed width="100%" height="100%" src="${url}" type="application/pdf" onload="window.print()" />
                    </body>
                </html>
            `);
            newTab.document.close();
        })
        .catch(err => {
            newTab.close();
            alert("Fehler beim Generieren des PDFs: " + err.message);
        });
    }

    function handleKeyDown(event) {
        if (event.key === "Enter") {
            event.preventDefault();
            getDataForReprint();
        }
    }

    function getDataForReprint() {
        debugger;
        AmagiLoader.show();
        const value = document.getElementById("barcodeInput").value;

        fetch('@Url.Action("getDataForReprint", "Assembly")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded'
            },
            body: 'bikeId=' + encodeURIComponent(value)
        })
        .then(response => response.json())
        .then(data => {
            debugger;
            if (!data.success) {
                AmagiLoader.hide();
                showErrorMessage(data.message);
                return;
            }

            const bike = data.data;
            document.getElementById("brand").innerText = bike.cr023_marke;
            document.getElementById("model").innerText = bike.cr023_beschreibung;
            document.getElementById("articleNumber").innerText = bike.cr023_productid;
            document.getElementById("ean").innerText = bike.cr023_barcodeean;
            document.getElementById("kategorie").innerText = bike.cr023_produktgruppe;
            document.getElementById("rahmentyp").innerText = bike.cr023_rahmentyp;
            document.getElementById("rahmenmaterial").innerText = bike.cr023_material;
            document.getElementById("schaltung").innerText = bike.cr023_getriebe;
            document.getElementById("radgroesse").innerText = bike.cr023_radgroe;
            document.getElementById("rahmenhoehe").innerText = bike.cr023_groe;
            document.getElementById("farbe").innerText = bike.cr023_farbe;
            document.getElementById("bikeBrand").value = bike.cr023_marke;

            if (bike.cr023_motor?.trim()) {
                document.getElementById("akku").innerText = bike.cr023_motor;
            } else {
                document.getElementById("akkuHead").style.display = "none";
            }

            if (data.imageUrl) {
                const img = document.getElementById("bikeImage");
                img.src = data.imageUrl;
                img.style.display = 'block';
            }

            const rawDate = data.assembleBikeData.AssembleEndTime;
            const timestamp = parseInt(rawDate.replace(/\/Date\((\d+)\)\//, '$1'));
            const date = new Date(timestamp);
            const formatted = `${String(date.getDate()).padStart(2, '0')}.${String(date.getMonth() + 1).padStart(2, '0')}.${date.getFullYear()} um ${String(date.getHours()).padStart(2, '0')}:${String(date.getMinutes()).padStart(2, '0')} Uhr`;
            document.getElementById('assemblerDate').textContent = formatted;
            document.getElementById('assemblerName').textContent = "Montiert von " + data.assemblerName;

            const checkbox = document.getElementById("isDifficultCheckbox");
            checkbox.checked = data.assembleBikeData.IsDifficult;
            checkbox.disabled = true;

            const navisondata = data.navisionData;
            document.getElementById("rePrintPreview-Seriennummer").innerText = navisondata[0].SerialNum;
            document.getElementById("rePrintPreview-Akkunummer").innerText = navisondata[0].BatteryNum;
            document.getElementById("rePrintPreview-Rahmennummer").innerText = navisondata[0].FrameNum;
            document.getElementById("rePrintPreview-Schlüsselnummer").innerText = data.assembleBikeData.KeyNumber || '--';
            document.getElementById("rePrintPreview-zubehorTasche").innerText = navisondata[0].AccessoryBag;

            // Hidden fields
            document.getElementById('rePrintRahmennummer').value = navisondata[0].FrameNum || '';
            document.getElementById('rePrintSchlüsselnummer').value = data.assembleBikeData.KeyNumber || '';
            document.getElementById('rePrintAkkunummer').value = navisondata[0].BatteryNum || '';
            document.getElementById('rePrintZubehoerTasche').value = navisondata[0].AccessoryBag || '';
            document.getElementById('rePrintGabelNummer').value = navisondata[0].ForkNum || '';
            document.getElementById('rePrintBikeId').value = navisondata[0].SerialNum || '';

            const formData = new URLSearchParams();
            formData.append('rahmennummer', navisondata[0].FrameNum || '');
            formData.append('Schlüsselnummer', data.assembleBikeData.KeyNumber || '');
            formData.append('Akkunummer', navisondata[0].BatteryNum || '');
            formData.append('zubehoerTasche', navisondata[0].AccessoryBag || '');
            formData.append('gabelNummer', navisondata[0].ForkNum || '');
            formData.append('bikeId', navisondata[0].SerialNum || '');

            fetch('@Url.Action("RePrintFahrradPass", "Assembly")', {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if (!response.ok) throw new Error('PDF generation failed');
                return response.blob();
            })
            .then(blob => {
                const url = URL.createObjectURL(blob);
                document.getElementById('fahrradPassIframe').src = url;
            })
            .catch(error => {
                AmagiLoader.hide();
                console.error('Error generating preview:', error);
                alert("Fahrradpass konnte nicht generiert werden.");
            });

            document.getElementById("bikeInfoBox").style.display = "block";
            document.getElementById("rePrintForm").style.display = "block";
            document.getElementById("isDifficultCheckboxContainer").style.display = "block";
            document.getElementById("homeScreen").style.display = "none";
            AmagiLoader.hide();
        })
        .catch(() => {
            AmagiLoader.hide();
            showErrorMessage("Serverfehler. Bitte später erneut versuchen.");
        });
    }

    function rePrintPdf() {
        debugger;
        const rahmen = document.getElementById("rePrintRahmennummer").value;
        const schluessel = document.getElementById("rePrintSchlüsselnummer").value;
        const akku = document.getElementById("rePrintAkkunummer").value;
        const zubehoer = document.getElementById("rePrintZubehoerTasche").value;
        const gabel = document.getElementById("rePrintGabelNummer").value;
        const bikeId = document.getElementById("rePrintBikeId").value;

        const formData = new FormData();
        formData.append('rahmennummer', rahmen);
        formData.append('Schlüsselnummer', schluessel);
        formData.append('Akkunummer', akku);
        formData.append('zubehoerTasche', zubehoer);
        formData.append('gabelNummer', gabel);
        formData.append('bikeId', bikeId);

        const newTab = window.open();
        if (!newTab) {
            alert("Bitte Pop-ups im Browser erlauben.");
            return;
        }

        fetch('@Url.Action("RePrintFahrradPass", "Assembly")', {
            method: 'POST',
            body: formData
        })
        .then(response => {
            if (!response.ok) throw new Error("Server error");
            return response.blob();
        })
        .then(blob => {
            const url = URL.createObjectURL(blob);
            setTimeout(() => {
                location.reload();
            }, 100);

            newTab.document.write(`
                <html>
                    <head><title>Fahrrad-Pass</title></head>
                    <body style="margin:0">
                        <embed width="100%" height="100%" src="${url}" type="application/pdf" onload="window.print()" />
                    </body>
                </html>
            `);
            newTab.document.close();
        })
        .catch(err => alert("Fehler beim Generieren des PDFs"));
    }
    </script>


