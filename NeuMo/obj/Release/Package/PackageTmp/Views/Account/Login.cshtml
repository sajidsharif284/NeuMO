@{
    ViewBag.Title = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Anmelden</title>
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body, html {
            height: 100%;
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .login-background {
            background-image: url('@Url.Content("~/content/images/loginbg.jpg")');
            background-size:cover;
            background-position: center;
            background-repeat: no-repeat;
            height: 100vh;
            justify-content: center;
            align-items: center;
            padding: 50px;
            overflow:hidden;
        }

        .login-box {
            background-color: white;
            padding: 50px;
            border-radius: 10px;
            max-width: 600px;
            width: 100%;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
            text-align: left; /* matches Figma alignment */
        }

        .btn-black {
            background-color: #000;
            color: white;
            font-weight: 600;
            padding: 12px;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .btn-black:hover {
            background-color: #222;
            color: white;
        }

        .form-control {
            border-radius: 6px;
            padding: 10px 14px;
            font-size: 14px;
        }

            .form-control::placeholder {
                color: #bbb;
                font-weight: 400;
            }

    </style>

    <script type="text/javascript">
        document.addEventListener('DOMContentLoaded', function () {
            debugger;
            const togglePassword = document.getElementById('togglePassword');
            if (togglePassword) {
                togglePassword.addEventListener('click', function () {
                    const passwordInput = document.getElementById('password');
                    const eyeIcon = document.getElementById('eyeIcon');

                    if (passwordInput.type === 'password') {
                        passwordInput.type = 'text';
                        eyeIcon.classList.remove('bi-eye');
                        eyeIcon.classList.add('bi-eye-slash');
                    } else {
                        passwordInput.type = 'password';
                        eyeIcon.classList.remove('bi-eye-slash');
                        eyeIcon.classList.add('bi-eye');
                    }
                });
            }
        });

        document.addEventListener("DOMContentLoaded", function () {
    var loginType = "@(ViewBag.LoginType ?? "employee")";
    if (loginType === "admin") {
        showAdminBox();
    } else {
        showEmployeeBox();
    }
});

        function showAdminBox() {
            document.getElementById('EmployeeBox').style.display = "none";
            document.getElementById('AdminBox').style.display = "block";

            // Remove required from Employee inputs
            document.querySelectorAll('#EmployeeBox [required]').forEach(el => el.removeAttribute('required'));

            // Add required to Admin inputs
            document.querySelectorAll('#AdminBox input').forEach(el => el.setAttribute('required', 'required'));
        }
        function showEmployeeBox() {
            document.getElementById('EmployeeBox').style.display = "block";
            document.getElementById('AdminBox').style.display = "none";

            // Remove required from Admin inputs
            document.querySelectorAll('#AdminBox [required]').forEach(el => el.removeAttribute('required'));

            // Add required to Employee inputs
            document.querySelectorAll('#EmployeeBox input').forEach(el => el.setAttribute('required', 'required'));
        }
    </script>


</head>
<body>
    <div class="login-background d-flex justify-content-center align-items-center">
        <div class="login-box text-center">
            <h3 class="mb-4 fw-bold">Anmelden</h3>
            <p class="mb-4  ">Melde dich hier mit deiner Daten an.</p>


            <form method="post" action="@Url.Action("Login", "Account")">
                <div id="EmployeeBox">
                    @if (ViewBag.EmployeeError != null)
                    {
                        <div class="alert alert-danger" role="alert">
                            @ViewBag.EmployeeError
                        </div>
                    }
                    <div class="mb-5 text-start">
                        <label for="employeeUsername" class="form-label fw-bold">Mitarbeiternummer</label>
                        <input type="text" class="form-control" id="employeeUsername" name="employeeUsername" placeholder="Mitarbeiternummer" autofocus />
                    </div>

                    <button type="submit" class="btn btn-black mt-2  w-100">
                        Anmelden
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" style="margin-left:10px" height="22" viewBox="0 0 23 22" fill="none">
                            <path d="M17.9167 10.0833H5.08333C4.07081 10.0833 3.25 10.9041 3.25 11.9166V18.3333C3.25 19.3458 4.07081 20.1666 5.08333 20.1666H17.9167C18.9292 20.1666 19.75 19.3458 19.75 18.3333V11.9166C19.75 10.9041 18.9292 10.0833 17.9167 10.0833Z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M6.91669 10.0833V6.41665C6.91669 5.20107 7.39957 4.03528 8.25911 3.17574C9.11866 2.3162 10.2844 1.83331 11.5 1.83331C12.7156 1.83331 13.8814 2.3162 14.7409 3.17574C15.6005 4.03528 16.0834 5.20107 16.0834 6.41665V10.0833" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </button>
                    <button type="button" class="btn mt-1 w-100" onclick="showAdminBox()">
                        <span style="color: #F85F68; font-weight: bold; text-decoration: underline;">Zum-Admin Login</span>
                    </button>
                </div>
                <div id="AdminBox" style="display:none">
                    @if (ViewBag.AdminError != null)
                    {
                        <div class="alert alert-danger" role="alert">
                            @ViewBag.AdminError
                        </div>
                    }
                    <div class="mb-3 text-start">
                        <label for="adminUsername" class="form-label fw-bold">Benutzername</label>
                        <input type="text" class="form-control" id="adminUsername" name="adminUsername" placeholder="Benutzername" autofocus />
                    </div>
                    <div class="mb-4 text-start">
                        <label for="password" class="form-label fw-bold">Passwort</label>
                        <div class="input-group">
                            <input type="password" class="form-control" id="password" name="password" placeholder="Passwort" />
                            <button type="button" class="btn btn-outline-secondary" id="togglePassword" tabindex="-1">
                                <i class="bi bi-eye" id="eyeIcon"></i>
                            </button>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-black  w-100">
                        Anmelden
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" style="margin-left:10px" height="22" viewBox="0 0 23 22" fill="none">
                            <path d="M17.9167 10.0833H5.08333C4.07081 10.0833 3.25 10.9041 3.25 11.9166V18.3333C3.25 19.3458 4.07081 20.1666 5.08333 20.1666H17.9167C18.9292 20.1666 19.75 19.3458 19.75 18.3333V11.9166C19.75 10.9041 18.9292 10.0833 17.9167 10.0833Z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M6.91669 10.0833V6.41665C6.91669 5.20107 7.39957 4.03528 8.25911 3.17574C9.11866 2.3162 10.2844 1.83331 11.5 1.83331C12.7156 1.83331 13.8814 2.3162 14.7409 3.17574C15.6005 4.03528 16.0834 5.20107 16.0834 6.41665V10.0833" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </button>
                    <button type="button" class="btn mt-1 w-100" onclick="showEmployeeBox()">
                        <span style="color: #F85F68; font-weight: bold; text-decoration: underline;">Zum Mitarbeiter-Login</span>
                    </button>
                </div>

            </form>
        </div>
    </div>
</body>
</html>
