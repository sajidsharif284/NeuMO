@model List<NeuMo.Controllers.UnPackingController.StorageSlotViewModel>
@{
    ViewBag.Title = "Lagerplätze";
    Layout = null;

}


<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>UnPackingAssign</title>
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />
