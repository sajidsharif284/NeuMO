        color: white;
        font-size: 18px;
        padding: 12px 20px;
        z-index: 9999;
    }

        .error-banner i {
            margin-right: 10px;
            font-size: 22px;
        }

    #errorText {
        flex-grow: 1;
    }

    #errorClose {
        cursor: pointer;
        font-weight: bold;
        padding-left: 15px;
        font-size: 22px;
    }
    #btnWarenausgang
    {
        border:2px solid black;
    }
    #printButton {
        border: 2px solid black;
    }
        .error-bannerForSendEmail {
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            background-color: green;
            color: white;
            font-size: 18px;
            padding: 12px 20px;
            z-index: 9999;
        }

            .error-bannerForSendEmail i {
                margin-right: 10px;
                font-size: 22px;
            }

        #errorTextForSendEmail {
            flex-grow: 1;
        }

        #errorCloseForSendEmail {
            cursor: pointer;
            font-weight: bold;
            padding-left: 15px;
            font-size: 22px;
        }
