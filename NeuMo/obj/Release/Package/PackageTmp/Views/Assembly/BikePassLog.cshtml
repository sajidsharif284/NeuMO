        let errorTimeout;

function showErrorMessage(message) {
    clearTimeout(errorTimeout);
    const banner = document.getElementById("errorMessage");
    const text = document.getElementById("errorText");
    text.textContent = message;
    banner.style.display = "flex";
    errorTimeout = setTimeout(() => {
        hideErrorMessage();
    }, 8000);
}

function hideErrorMessage() {
    document.getElementById("errorMessage").style.display = "none";

}

function rePrintBarcodeFromPreview(previewId) {
    //const value = document.getElementById(previewId)?.innerText.trim();
    const element = document.getElementById(previewId);
    const value = (element.tagName === "INPUT" || element.tagName === "TEXTAREA")
        ? element.value.trim()
        : element.innerText.trim();
    if (!value || value === "--") return;

    const formData = new FormData();
    formData.append("headingValue", previewId);
    formData.append("barcodeValue", value);

    //const newTab = window.open();
    //if (!newTab) {
    //    alert("Bitte Pop-ups im Browser erlauben.");
    //    return;
    //}

    // Open placeholder tab immediately (browser won’t block this)
    const newTab = window.open("", "_blank");

    fetch('@Url.Action("GenerateBarcodePdf", "Assembly")', {
        method: 'POST',
        body: formData
    })
        .then(response => {
            debugger;
            if (!response.ok) throw new Error("Server error");


            const contentType = response.headers.get("content-type") || "";

            if (contentType.includes("application/pdf")) {
                return response.blob().then(blob => {
                    const url = URL.createObjectURL(blob);
                    newTab.document.write(`
                      <html>
                      <head><title>Fahrrad-Pass</title></head>
                      <body style="margin:0">
                      <div style="background-color:red; color:white; font-weight:bold;
                       text-align:center; padding:15px; font-size:18px;">
                       Drucker Einstellung fehlt
                        </div>
                        <embed width="100%" height="100%" src="${url}" type="application/pdf" />
                        </body>
                        </html>
                         `);
                    newTab.document.close();
                });
            } else {
                // ✅ Printer set → just show message
                return response.json().then(data => {
                    if (data.success) {
                        //showErrorMessageForSendEmail("Etikett wurde gedruckt.");
                        alert("Etikett wurde gedruckt");
                    } else {
                        // ❌ Backend reported failure
                        showErrorMessage(data.message || "Fehler beim Speichern.");
                        console.error("Detail:", data.detail);
                    }
                    newTab.close(); // no need for tab in this case
                });
            }
        })
        .catch(err => {
            console.error("Fehler:", err);
            newTab.close();
            alert("Fehler beim Generieren des PDFs");
        });
}



                function getDataForReprint(button) {
    debugger;
    AmagiLoader.show();
    const id = button.dataset.id;
    const frameNum = button.dataset.frame;

    fetch('@Url.Action("getDataForReprint", "Assembly")', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded'
        },
        body: 'id=' + encodeURIComponent(id) + '&frameNo=' + encodeURIComponent(frameNum)
    })
    .then(response => response.json())
    .then(data => {
        debugger;
        if (!data.success) {
            AmagiLoader.hide();
            showErrorMessage(data.message);
            return;
        }

        const bike = data.data;
        document.getElementById("brand").innerText = bike.Brand;
        document.getElementById("model").innerText = bike.Description;
        document.getElementById("articleNumber").innerText = bike.No_;
        document.getElementById("ean").innerText = bike.EAN;

        document.getElementById("kategorie").innerText = bike.Item_Category_Code;
        document.getElementById("rahmentyp").innerText = bike.Frame_Type;
        document.getElementById("rahmenmaterial").innerText = bike.Frame_Material;
        document.getElementById("schaltung").innerText = bike.Gearshift;
        document.getElementById("radgroesse").innerText = bike.Wheel_Size;
        document.getElementById("rahmenhoehe").innerText = bike.Frame_Height;
        document.getElementById("farbe").innerText = bike.ColourForName;
        document.getElementById("bikeBrand").value = bike.Brand;

        if (bike.E_Bike_Engine?.trim()) {
            document.getElementById("akku").innerText = bike.E_Bike_Engine;
        } else {
            document.getElementById("akkuHead").style.display = "none";
        }

        if (data.imageUrl) {
            const img = document.getElementById("bikeImage");
            img.src = data.imageUrl;
            img.style.display = 'block';
        }

        if (data.assembleBikeData.Status !== "Logix") {

            document.getElementById("HistoryData").style.display = "block";

            const rawDate = data.assembleBikeData.AssembleEndTime;
            const timestamp = parseInt(rawDate.replace(/\/Date\((\d+)\)\//, '$1'));
            const date = new Date(timestamp);
            const formatted = `${String(date.getDate()).padStart(2, '0')}.${String(date.getMonth() + 1).padStart(2, '0')}.${date.getFullYear()} um ${String(date.getHours()).padStart(2, '0')}:${String(date.getMinutes()).padStart(2, '0')} Uhr`;
            document.getElementById('assemblerDate').textContent = formatted;
            document.getElementById('assemblerName').textContent = "Montiert von " + data.assemblerName;

            const assembleBikeData = data.assembleBikeData;
            if (data.unpackerName !== "") {
                document.getElementById("unpackerHistory").style.display = "block";

                const rawDateTwo = assembleBikeData.DateTime;
                const timestampTwo = parseInt(rawDateTwo.replace(/\/Date\((\d+)\)\//, '$1'));
                const dateTwo = new Date(timestampTwo);
                const formattedTwo = `${String(dateTwo.getDate()).padStart(2, '0')}.${String(dateTwo.getMonth() + 1).padStart(2, '0')}.${dateTwo.getFullYear()} um ${String(dateTwo.getHours()).padStart(2, '0')}:${String(dateTwo.getMinutes()).padStart(2, '0')} Uhr`;
                document.getElementById('unpackerDate').textContent = formattedTwo;
                document.getElementById('unpackerName').textContent = "Auspacker von " + data.unpackerName;
            }
        }
        else {
            document.getElementById("btnSubmitRahmen").style.display = "none";
            
        }
        



        const checkbox = document.getElementById("isDifficultCheckbox");
        checkbox.checked = data.assembleBikeData.IsDifficult;
        checkbox.disabled = true;

        const navisondata = data.navisionData;
        document.getElementById("rePrintPreview-Seriennummer").innerText = navisondata[0].SerialNum;
        document.getElementById("rePrintPreview-Akkunummer").value = navisondata[0].BatteryNum;
        document.getElementById("rePrintPreview-Rahmennummer").value = navisondata[0].FrameNum;
        document.getElementById("rePrintPreview-Schlüsselnummer").value = data.assembleBikeData.KeyNumber || '--';
        document.getElementById("rePrintPreview-zubehorTasche").value = navisondata[0].AccessoryBag;

        // Hidden fields
        document.getElementById('rePrintRahmennummer').value = navisondata[0].FrameNum || '';
        document.getElementById('rePrintSchlüsselnummer').value = data.assembleBikeData.KeyNumber || '';
        document.getElementById('rePrintAkkunummer').value = navisondata[0].BatteryNum || '';
        document.getElementById('rePrintZubehoerTasche').value = navisondata[0].AccessoryBag || '';
        document.getElementById('rePrintGabelNummer').value = navisondata[0].ForkNum || '';
        document.getElementById('rePrintBikeId').value = navisondata[0].SerialNum || '';
        document.getElementById('rePrintBearbeiter').value = data.employeeNumber || '';

        const formData = new URLSearchParams();
        formData.append('rahmennummer', navisondata[0].FrameNum || '');
        formData.append('Schlüsselnummer', data.assembleBikeData.KeyNumber || '');
        formData.append('Akkunummer', navisondata[0].BatteryNum || '');
        formData.append('zubehoerTasche', navisondata[0].AccessoryBag || '');
        formData.append('gabelNummer', navisondata[0].ForkNum || '');
        formData.append('bikeId', navisondata[0].SerialNum || '');
        formData.append('barcode', bike.Bar_Code || '');
        formData.append('bearbeiterName', data.employeeNumber || '');

        formData.append('preview',  '1');

        fetch('@Url.Action("RePrintFahrradPass", "Assembly")', {
            method: 'POST',
            body: formData
        })
        .then(response => {
            if (!response.ok) throw new Error('PDF generation failed');
            return response.blob();
        })
        .then(blob => {
            const url = URL.createObjectURL(blob);
            document.getElementById('fahrradPassIframe').src = url;
        })
        .catch(error => {
            AmagiLoader.hide();
            console.error('Error generating preview:', error);
            alert("Fahrradpass konnte nicht generiert werden.");
        });

        document.getElementById("RePrintingParentData").style.display = "block";
        document.getElementById("isDifficultCheckboxContainer").style.display = "block";
        document.getElementById("BikePassLogData").style.display = "none";
        AmagiLoader.hide();
    })
        .catch((error) => {
            debugger;
            AmagiLoader.hide();
        showErrorMessage("Serverfehler. Bitte später erneut versuchen.");
    });
}

