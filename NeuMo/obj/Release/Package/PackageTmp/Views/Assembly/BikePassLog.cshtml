            <div class="col-md-11 table-container" id="BikePassLogData" style="">
                <div class="mt-5">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3>FahrradPassLog</h3>

                        <!-- ⭐ TOP RIGHT: Branch Name -->
                        <h4 class="text-end" style="font-weight:700; font-size:26px;">
                            <span style="color:#e1005a;">Emporon</span> @ViewBag.BranchName
                        </h4>

                    </div>



                </div>
                <!-- 📄 Pagination Controls -->
                <!-- 📄 Pagination Controls -->
                <div class="d-flex justify-content-between align-items-center flex-wrap">
                    <!-- Pagination -->
                    <div class="pagination-container d-flex align-items-center">
                        @Html.PagedListPager(
                            Model,
                            page => Url.Action("BikePassLog", new { page, search = ViewBag.CurrentFilter, branch = ViewBag.CurrentBranch }),
                            new PagedListRenderOptions
                            {
                                DisplayLinkToFirstPage = PagedListDisplayMode.Always,
                                DisplayLinkToLastPage = PagedListDisplayMode.Always,
                                DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
                                DisplayLinkToNextPage = PagedListDisplayMode.Always,
                                DisplayEllipsesWhenNotShowingAllPageNumbers = true,
                                MaximumPageNumbersToDisplay = 7,
                                UlElementClasses = new[] { "pagination", "pagination-lg", "custom-pagination" },
                                LiElementClasses = new[] { "page-item" }
                            })
                    </div>

                    <!-- Search Form -->
                    <form method="get" action="@Url.Action("BikePassLog")" class="d-flex align-items-center">
                        <!-- 🏢 Branch dropdown -->
                        <select name="branch" class="form-select me-2 w-auto" style="height:40px;">
                            <option value="">Alle Filialen</option>
                            @foreach (var b in ViewBag.Branches as List<string>)
                            {
                                <option value="@b" @(ViewBag.CurrentBranch == b ? "selected" : "")>@b</option>
                            }
                        </select>

                        <input type="text"
                               name="search"
                               value="@ViewBag.CurrentFilter"
                               class="form-control me-2"
                               style="height:40px; width:250px;"
                               placeholder="Seriennummer oder RahmenNr suchen..." />

                        <button type="submit"
                                class="btn btn-primary mb-3"
                                style="height:40px">
                            🔍 Suchen
                        </button>
                        <a href="@Url.Action("BikePassLog")" class="btn btn-secondary ms-2" style="height:40px;">
                            ✖ Clear
                        </a>
                    </form>
                </div>

                <!-- User Table -->
                <!-- Scrollable Table with Sticky Header -->
                <div class="custom-table-wrapper">
                    <table class="table table-bordered table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>@Html.DisplayNameFor(model => model.FirstOrDefault().Date)</th>
                                <th>@Html.DisplayNameFor(model => model.FirstOrDefault().Barcode)</th>
                                <th>Seriennummer</th>
                                <th>RahmenNr</th>
                                <th>Filiale</th>
                                <th>Bearbeiter</th>
                                <th>Monteur</th>
                                <th>ZubehörNr</th>
                                <th>AkkuNr</th>
                                <th>SchlüsselNr</th>
                                <th></th>
                            </tr>
                            @*<tr>
                        <th><input type="text" class="form-control form-control-sm column-search" /></th>
                        <th><input type="text" class="form-control form-control-sm column-search" /></th>
                        <th><input type="text" class="form-control form-control-sm column-search" /></th>
                        <th><input type="text" class="form-control form-control-sm column-search" /></th>
                        <th><input type="text" class="form-control form-control-sm column-search" /></th>
                        <th><input type="text" class="form-control form-control-sm column-search" /></th>
                        <th><input type="text" class="form-control form-control-sm column-search" /></th>
                        <th><input type="text" class="form-control form-control-sm column-search" /></th>
                        <th><input type="text" class="form-control form-control-sm column-search" /></th>
                        <th><input type="text" class="form-control form-control-sm column-search" /></th>
                    </tr>*@
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@(item.Date.HasValue ? item.Date.Value.ToString("dd.MM.yyyy") : "")</td>
                                        <td>@Html.DisplayFor(m => item.Barcode)</td>
                                        <td>@Html.DisplayFor(m => item.SerialNumber)</td>
                                        <td>@Html.DisplayFor(m => item.Frame_Num)</td>
                                        <td>@Html.DisplayFor(m => item.BranchName)</td>
                                        <td>@Html.DisplayFor(m => item.Monteur)</td>
                                        <td>@Html.DisplayFor(m => item.Mechaniker)</td>
                                        <td>@Html.DisplayFor(m => item.AccesoryBag)</td>
                                        <td>@Html.DisplayFor(m => item.BatteryNumber)</td>
                                        <td>@Html.DisplayFor(m => item.KeyNumber)</td>
                                        <td>
                                            <button type="button" id="reprintAllData"
                                                    onclick="getDataForReprint(this)"
                                                    data-id="@item.Id"
                                                    data-frame="@item.Frame_Num"
                                                    class="reprint-button"
                                                    style="height:10px"
                                                    title="Fahrradpass & Etikett erneut drucken">
                                                <i class="bi bi-qr-code-scan unPackerIcon"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="11" class="text-center">Keine Daten gefunden.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>





                @if (TempData["AlertMessage"] != null)
                {
                    <script type="text/javascript">
                       alert('@TempData["AlertMessage"]');
                    </script>
                }
