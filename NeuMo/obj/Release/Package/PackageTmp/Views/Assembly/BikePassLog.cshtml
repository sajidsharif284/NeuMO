        function getBikepassPdf() {
            debugger;
            const rahmen = document.getElementById("rePrintRahmennummer").value;
            const schluessel = document.getElementById("rePrintSchlüsselnummer").value;
            const akku = document.getElementById("rePrintAkkunummer").value;
            const zubehoer = document.getElementById("rePrintZubehoerTasche").value;
            const gabel = document.getElementById("rePrintGabelNummer").value;
            const bikeId = document.getElementById("rePrintBikeId").value;
            const bearbeiter = document.getElementById("rePrintBearbeiter").value;

            const formData = new FormData();
            formData.append('rahmennummer', rahmen);
            formData.append('Schlüsselnummer', schluessel);
            formData.append('Akkunummer', akku);
            formData.append('zubehoerTasche', zubehoer);
            formData.append('gabelNummer', gabel);
            formData.append('bikeId', bikeId);
            formData.append('preview', '1');
            formData.append('bearbeiterName', bearbeiter);

            const newTab = window.open();
            if (!newTab) {
                alert("Bitte Pop-ups im Browser erlauben.");
                return;
            }

    fetch('@Url.Action("RePrintFahrradPass", "Assembly")', {
        method: 'POST',
        body: formData
    })
                .then(response => {
                    if (!response.ok) throw new Error("Server error");
                    return response.blob();
                })
                .then(blob => {
                    const url = URL.createObjectURL(blob);

                    // Write HTML that embeds the PDF and triggers print
                    newTab.document.write(`
                    <html>
                    <head>
                       <title>Fahrrad-Pass</title>
                       </head>
                      <body style="margin:0">
                      <embed width="100%" height="100%" src="${url}" type="application/pdf" onload="window.print()" />

                      </body>
                     </html>
                     `);

                    newTab.document.close();

                })
                .catch(err => alert("Fehler beim Generieren des PDFs"));
        }

        function submitRahmenNumber() {
    debugger;
            AmagiLoader.show();
    const rahmenInput = document.getElementById("rePrintPreview-Rahmennummer");
            const bikeIdInput = document.getElementById("rePrintPreview-Seriennummer").innerText;

    if (!rahmenInput || !bikeIdInput) {
        console.error("Rahmennummer or BikeId input not found.");
        return;
    }

    const rahmenNumber = rahmenInput.value.trim();
            const bikeId = bikeIdInput;
            const akku = document.getElementById("rePrintPreview-Akkunummer").value;
            const key = document.getElementById("rePrintPreview-Schlüsselnummer").value;
            const zubehor = document.getElementById("rePrintPreview-zubehorTasche").value;



    if (!rahmenNumber) {
        AmagiLoader.hide();
        alert("Bitte geben Sie eine gültige Rahmennummer ein!");
        return;
    }

    if (!bikeId) {
        AmagiLoader.hide();
        alert("Bike ID fehlt — bitte überprüfen!");
        return;
    }

    fetch('@Url.Action("UpdateRahmennummer", "Assembly")', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({
            rahmennummer: rahmenNumber,
            bikeId: bikeId,
            akku: akku,
            key: key,
            zubehor: zubehor
        })
    })
    .then(response => {
        if (!response.ok) {
            AmagiLoader.hide();
            throw new Error("HTTP error " + response.status);
        }
        return response.json();
    })
    .then(data => {
        if (data.success) {
            AmagiLoader.hide();
            alert(`✅ Rahmennummer '${rahmenNumber}' erfolgreich gespeichert (Seriennummer: ${bikeId}).`);
            // Refresh the page after the user clicks OK
            location.reload();
        } else {
            AmagiLoader.hide();
            alert("⚠️ Fehler: " + (data.message || "Unbekannter Fehler."));
        }
    })
    .catch(error => {
        AmagiLoader.hide();
        console.error('❌ Error:', error);
        alert('Fehler beim Speichern der Rahmennummer.');
    });
}

