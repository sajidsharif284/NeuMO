        document.addEventListener("DOMContentLoaded", function () {
            debugger;
            const msg = localStorage.getItem("emailMessage");
            if (msg) {
                showErrorMessageForSendEmail(msg);
                localStorage.removeItem("emailMessage");
            }
        });

        document.addEventListener('DOMContentLoaded', () => {
            const openButtons = document.querySelectorAll('.btn-mangel-open'); // handles multiple buttons
            const modalContainer = document.querySelector('.mangel-modal-container');
            const closeButton = document.querySelector('.btn-mangel-close');
            const submitButton = document.querySelector('.modal-btn.report');

            if (openButtons.length && modalContainer && closeButton && submitButton) {
                openButtons.forEach(button => {
                    button.addEventListener('click', () => {
                        modalContainer.style.display = 'flex';

                        // Get textarea inside modal
                        const textarea = modalContainer.querySelector('.modal-textarea');

                        // Optional: Clear old comment
                        textarea.value = '';

                        // Focus the textarea so typing goes here
                        textarea.focus();
                    });
                });

                closeButton.addEventListener('click', () => {
                    modalContainer.style.display = 'none';
                });

                window.addEventListener('click', (e) => {
                    if (e.target === modalContainer) {
                        modalContainer.style.display = 'none';
                    }
                });

                submitButton.addEventListener('click', async () => {
                    modalContainer.style.display = 'none';
                    AmagiLoader.show();


                    const comment = document.querySelector('.modal-textarea').value;
                    const files = [
                        document.getElementById('img1').files[0],
                        document.getElementById('img2').files[0],
                        document.getElementById('img3').files[0],
                        document.getElementById('img4').files[0]
                    ].filter(file => file !== undefined);

                    const formData = new FormData();
                    const bikeId = document.getElementById("bikeId").value;
                    const barcode = document.getElementById("getBarcodeFromApi").value;

                    formData.append('Comment', comment);
                    formData.append('bikeId', bikeId);
                    formData.append('barcode', barcode);

                    formData.append("UnPackingWithFrameNumber", document.getElementById("UnPackingWithFrameNumber").value);
                    files.forEach(file => {
                        formData.append('Images', file); // Note: use same name "Images" to bind as IEnumerable<HttpPostedFileBase>
                    });
                    try {
                        const response = await fetch('@Url.Action("Melden", "Assembly")', {
                            method: 'POST',
                            body: formData
                        });

                        debugger;
                        const data = await response.json();
                        if (data.success) {
                            AmagiLoader.hide();
                            location.reload();
                            const userKey = '@ViewBag.UserNameAndCompany';
                            localStorage.removeItem(`uiState_${userKey}`);

                        } else {
                            AmagiLoader.hide();
                            showErrorMessage(data.message); // Show the message from the server
                        }
                    } catch (error) {
                        AmagiLoader.hide();
                        console.error('Fehler:', error);
                        showErrorMessage('Netzwerkfehler.');
                    }


                });
            }
        });

        document.addEventListener('DOMContentLoaded', function () {
            const fileInputs = document.querySelectorAll('.upload-box input[type="file"]');

            fileInputs.forEach(input => {
                input.addEventListener('change', function () {
                    const file = this.files[0];
                    if (file) {
                        const reader = new FileReader();
                        reader.onload = (e) => {
                            const previewDiv = this.parentElement.querySelector('.preview-image');
                            previewDiv.innerHTML = `<img src="${e.target.result}" style="width:100%; height:100%; object-fit:cover;" />`;
                        };
                        reader.readAsDataURL(file);
                    }
                });
            });
        });

        document.addEventListener("DOMContentLoaded", function () {
            const form = document.getElementById("fahrradForm");

            form.addEventListener("keydown", function (e) {
                if (e.key === "Enter") {
                    e.preventDefault(); // stop form from submitting

                    const inputs = Array.from(form.querySelectorAll("input, select"));
                    const index = inputs.indexOf(e.target);

                    if (index > -1 && index < inputs.length - 1) {
                        inputs[index + 1].focus();
                    }
                }
            });
        });


    </script>

