                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label for="zubehoerTasche">Zubehör-Behälter Nr</label>
                                                <input type="text" class="form-control" name="zubehoerTasche" id="zubehoerTasche" oninput="updatePreview('zubehoerTasche')">
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row mb-3">
                                        <div class="col-md-4 offset-md-2">
                                            <div class="form-group">
                                                <label for="Mechaniker">Monteur <span style="color:red">*</span></label>
                                                <select id="mechanicDropdown" name="mechanicDropdown" class="form-control" onchange="validateFields()"></select>
                                            </div>

                                        </div>
                                    </div>
                                    <input type="hidden" name="UnPackingWithFrameNumber" id="UnPackingWithFrameNumber" />

                                </form>

                                <!-- Info Box at the bottom -->
                                <div class="mt-4 p-3 border rounded text-center bg-light" id="notifyAdmin" style="font-size: 15px; display:none">
                                    Hat sich die Logik der Rahmennummer geändert? Sag deinem Admin
                                    <a href="#"
                                       id="notifyAdminLink"
                                       class="fw-bold"
                                       style="color:#e1005a; text-decoration: underline;"
                                       onclick="notifyAdminFrameNo(); return false;">
                                         hier Bescheid.
                                    </a>
                                </div>

                            </div>

                        </div>
                    </div>
                    <!-- Right panel -->
                    <div class="col-md-3">
                        <div class="d-flex justify-content-between align-items-center mt-3 me-4">
                            <h3></h3>
                            <h4 class="text-end" style="font-weight:700; font-size:26px;">
                                <span style="color:#e1005a;">Emporon</span> @ViewBag.BranchName
                            </h4>
                        </div>
                        <div class="right-panel">
                            <div class="preview-section" id="previewSection" style="display:none">
                                <h3 class="">Etiketten & Nummern drucken</h3>
                                <div class="row mt-3">
                                    <div class="col-md-2">
                                        <span class="print-icon printIcons" onclick="printBarcodeFromPreview('preview-Seriennummer')" title="Drucken">🖨️</span>
                                    </div>
                                    <div class="col-md-10">
                                        <h6 class="fw-bold mb-0">Seriennummer:</h6>
                                        <p id="preview-Seriennummer">--</p>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-2">
                                        <span class="print-icon printIcons" onclick="printBarcodeFromPreview('preview-Rahmennummer')" title="Drucken">🖨️</span>
                                    </div>
                                    <div class="col-md-10">
                                        <h6 class="fw-bold mb-0">Rahmennummer:</h6>
                                        <p id="preview-Rahmennummer">--</p>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-2">
                                        <span class="print-icon printIcons" onclick="printBarcodeFromPreview('preview-Schlüsselnummer')" title="Drucken">🖨️</span>
                                    </div>
                                    <div class="col-md-10 ">
                                        <h6 class="fw-bold mb-0">Schlüsselnummer:</h6>
                                        <p id="preview-Schlüsselnummer">--</p>

                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-2">
                                        <span class="print-icon printIcons" onclick="printBarcodeFromPreview('preview-Akkunummer')" title="Drucken">🖨️</span>
                                    </div>
                                    <div class="col-md-10">
                                        <h6 class="fw-bold mb-0">Akkunummer:</h6>
                                        <p id="preview-Akkunummer">--</p>

                                    </div>
                                </div>


                                @*<div class="row">
                    <div class="col-md-12">
                        <h6 class="fw-bold mb-0">Gabel-Nummer:</h6>
                        <p id="preview-gabelNummer">--</p>

                    </div>
                </div>*@
                                <div class="row">
                                    <div class="col-md-12">
                                        <h6 class="fw-bold mb-0">Zubehör-Behälter Nr:</h6>
                                        <p id="preview-zubehoerTasche">--</p>

                                    </div>
                                </div>

                                <div id="">
                                    <button type="button" id="printBtn" onclick="generateAndPrintPdf()" disabled class="btn btn-dark mt-3 w-100">
                                        Fahrradpass Drucken <span class="print-icon" title="Drucken">🖨️</span>
                                    </button>
                                    <button type="button" id="completeJobBtn" onclick="completeJobButton()" disabled class="btn btn-dark mt-3 w-100">
                                        Abschließen
                                    </button>
                                    <button id="btnCancelJob" type="button" class="btn mt-0 w-100" onclick="cancelJobButton()">
                                        <i class="bi bi-exclamation-triangle" style="color: #F85F68; font-size: 24px;"></i>
                                        <span style="color: #F85F68; font-weight: bold; text-decoration: underline;">Abbrechen</span>
                                    </button>
                                    <button type="button" class="btn-mangel-open btn  w-100">
                                        <i class="bi bi-exclamation-triangle" style="color: #F85F68; font-size: 24px;"></i>
                                        <span style="color: #F85F68; font-weight: bold; text-decoration: underline;">Mangel melden</span>
                                    </button>
                                </div>

                            </div>

                            <div id="homeScreen">
                                <div class="scanner-box" id="ScannedBox">
                                    <form asp-controller="Scanner" asp-action="Scan" method="post" id="scanForm">
                                        <input type="text" id="barcodeInput" name="barcode" placeholder="Bitte scanne das Fahrrad" autofocus />
                                    </form>
                                </div>

                            </div>
                            <div id="bikeInfoBox" style="display:none;">
                                <img id="bikeImage" src="" alt="Produktbild" style="width:270px ; height:150px; margin-bottom:5px; display:none;" />
                                <strong>Marke:</strong> <span id="brand"></span><br />
                                <strong>Model:</strong> <span id="model"></span><br />
                                <strong>Artikelnummer:</strong> <span id="articleNumber"></span><br />
                                <strong>EAN:</strong> <span id="ean"></span>

                                <div id="extraInfo" class="mt-3 mb-4">
                                    @*<p style="cursor: pointer;" id="toggleInfo">
                        <i class="bi bi-info-circle m-1" style="font-size: 15px;"></i>
                        <strong>Zusätzliche Informationen</strong>
                        <i id="toggleInfoIcon" class="bi bi-chevron-down m-1" style="font-size: 15px;"></i>
                    </p>*@
                                    <ul id="extraInfoList" style="list-style: none;padding: 0;">
                                        <li><strong>Kategorie:</strong> <span id="kategorie"></span></li>
                                        <li><strong>Rahmentyp:</strong> <span id="rahmentyp"></span></li>
                                        <li><strong>Rahmenmaterial:</strong> <span id="rahmenmaterial"></span></li>
                                        <li><strong>Schaltung:</strong> <span id="schaltung"></span></li>
                                        <li><strong>Radgröße:</strong> <span id="radgroesse"></span></li>
                                        <li><strong>Rahmenhöhe:</strong> <span id="rahmenhoehe"></span></li>
                                        <li><strong>Farbe:</strong> <span id="farbe"></span></li>
                                        <li id="akkuContainer"><strong>Akku:</strong> <span id="akku"></span></li>
                                    </ul>
                                </div>
                                <input type="hidden" name="bikeId" id="bikeId" />
                                <input type="hidden" name="bikeBrand" id="bikeBrand" />
                                <input type="hidden" name="bikeFrameNr" id="bikeFrameNr" />
                                <input type="hidden" name="getBarcodeFromApi" id="getBarcodeFromApi" />
                                <input type="hidden" id="isEbike" name="isEbike" />
                                <input type="hidden" id="isRCategory" name="isRCategory" />
                                <input type="hidden" name="selectedMechanic" id="selectedMechanic" />

                                <div id="isDifficultCheckboxContainer" class="form-check mt-1">
                                    <input class="form-check-input" name="isDifficultCheckbox" type="checkbox" id="isDifficultCheckbox" />
                                    <label class="form-check-label" for="isDifficultCheckbox">
                                        Schweres Rad
                                    </label>
                                </div>
                                <div id="scanBikeDataExist">
                                    <button type="button" class="btn btn-dark mt-1 w-100" onclick="showPrintDataForm()">
                                        Daten Korrekt <i id="tickIcon" class="bi bi-check2"></i>
                                    </button>
                                    <button id="btnDataNotCorrect" type="button" class="btn btn-danger mt-1 w-100" onclick="inCompleteJobButton()">
                                        Daten nicht Korrekt <i id="tickIcon" class="bi bi-check2"></i>
                                    </button>
                                    <button id="btnCancelJob" type="button" class="btn mt-0 w-100" onclick="cancelJobButton()">
                                        <i class="bi bi-exclamation-triangle" style="color: #F85F68; font-size: 20px;"></i>
                                        <span style="color: #F85F68; font-weight: bold; text-decoration: underline;">Abbrechen</span>
                                    </button>
                                    <button type="button" class="btn-mangel-open btn mt-0 w-100">
                                        <i class="bi bi-exclamation-triangle" style="color: #F85F68; font-size: 20px;"></i>
                                        <span style="color: #F85F68; font-weight: bold; text-decoration: underline;">Mangel melden</span>
                                    </button>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
