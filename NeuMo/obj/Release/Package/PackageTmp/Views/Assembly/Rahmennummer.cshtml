                            </div>
                        </div>
                    </div>
                </div>



                @if (TempData["AlertMessage"] != null)
                {
                    <script type="text/javascript">
                   alert('@TempData["AlertMessage"]');
                    </script>
                }
            </div>




        </div>
    </div>
    <!-- First-Time Password Modal -->
    <div class="modal fade" id="pagePasswordModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Zugangsschutz</h5>
                </div>

                <div class="modal-body">
                    <label class="form-label fw-semibold">Passwort eingeben</label>
                    <input id="pagePasswordInput" type="password" class="form-control" placeholder="Passwort...">
                    <small id="passwordError" class="text-danger mt-2 d-none">Falsches Passwort!</small>
                </div>

                <div class="modal-footer">
                    <button id="submitPagePassword" class="btn btn-dark w-100">Weiter</button>
                </div>

            </div>
        </div>
    </div>

</body>
</html>
